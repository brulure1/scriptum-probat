---
interface Props {
	href: string;
	title: string;
	answer: string;
	category?: string;
	categoryLabel?: string;
	confidenceClass?: string;
	confidenceLabel?: string;
	accent?: string;
	index?: number;
}

const {
	href,
	title,
	answer,
	categoryLabel,
	confidenceClass = '',
	confidenceLabel,
	accent = 'default',
	index = 0,
} = Astro.props;

const delay = `${index * 0.07}s`;
---

<li
	class="sp-fiche-card-wrap sp-animate-in"
	data-accent={accent}
	style={`animation-delay: ${delay}`}
>
	<a href={href} class="sp-fiche-card">
		<span class="sp-fiche-card__shine" aria-hidden="true"></span>
		<div class="sp-fiche-card__meta">
			{categoryLabel && <span class="sp-tag sp-tag--cat">{categoryLabel}</span>}
			{confidenceLabel && <span class={`sp-badge ${confidenceClass}`}>{confidenceLabel}</span>}
		</div>
		<h3>{title}</h3>
		<p>{answer}</p>
		<span class="sp-fiche-card__cta">Lire la fiche →</span>
	</a>
</li>
